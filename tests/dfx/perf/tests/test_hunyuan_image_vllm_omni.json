                                "distributed_executor_backend": "mp",
                                "quantization": "fp8",
                                "parallel_config": {
                                    "tensor_parallel_size": 4
                                }
                            },
                            "final_output": true,
                            "final_output_type": "image"
                        }
                    ]
                },
                "enable-diffusion-pipeline-profiler": true
            }
        },
        "benchmark_params": [
            {
                "name": "1024x1024_steps50",
