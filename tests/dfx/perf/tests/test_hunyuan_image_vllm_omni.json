                "task": "t2i",
                "width": 1024,
                "height": 1024,
                "num-inference-steps": 50,
                "num-prompts": 10,
                "max-concurrency": 1,
                "baseline": {
                    "throughput_qps": 0.001,
                    "latency_p99": 1000.0,
                    "peak_memory_mb_max": 400000,
